<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.folloze.codex-skills-sync</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>__REPO_ROOT__/scripts/sync_codex_skills.py</string>
    <string>--repo-root</string>
    <string>__REPO_ROOT__</string>
    <string>--pull</string>
    <string>--overwrite</string>
    <string>--prune</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>3600</integer>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__</string>
  <key>StandardOutPath</key>
  <string>/tmp/com.folloze.codex-skills-sync.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/com.folloze.codex-skills-sync.err.log</string>
</dict>
</plist>
